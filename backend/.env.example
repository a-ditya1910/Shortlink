# Copy this file to .env — only needed if you want to override defaults

PORT=4000
NODE_ENV=production

# Railway MySQL URL (Railway → MySQL service → Connect tab)
DATABASE_URL=mysql://root:password@junction.proxy.rlwy.net:PORT/railway
DATABASE_SSL=false

# Render internal Redis URL (Render → Redis service → Internal URL)
REDIS_URL=redis://red-xxxxxxxxxx:6379

# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_strong_random_secret

# Your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app

# Your Render backend URL — used to build short links stored in DB
APP_URL=https://your-backend.onrender.com
